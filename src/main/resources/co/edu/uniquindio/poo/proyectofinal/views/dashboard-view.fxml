<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!-- Dashboard del administrador -->
<ScrollPane fitToWidth="true" styleClass="scroll-pane"
            xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../css/css.css"
            fx:controller="co.edu.uniquindio.poo.proyectofinal.viewController.DashboardController">

    <VBox spacing="24" styleClass="main-content">

        <!-- Encabezado -->
        <VBox spacing="4">
            <Label text="Dashboard" styleClass="page-title"/>
            <Label text="Resumen general de la plataforma" styleClass="page-subtitle"/>
        </VBox>

        <!-- Stat cards — fila 1 -->
        <GridPane hgap="16" vgap="16">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
            </columnConstraints>

            <!-- Card: Total Eventos -->
            <VBox styleClass="stat-card" spacing="12" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox styleClass="stat-icon-indigo" alignment="CENTER">
                        <Label text="🗓" style="-fx-font-size:20px;"/>
                    </VBox>
                    <VBox spacing="2">
                        <Label text="Total Eventos" styleClass="stat-label"/>
                        <Label fx:id="lblTotalEventos" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
                <Label fx:id="lblTendenciaEventos" text="↑ activos" styleClass="stat-trend-up"/>
            </VBox>

            <!-- Card: Total Usuarios -->
            <VBox styleClass="stat-card" spacing="12" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox styleClass="stat-icon-emerald" alignment="CENTER">
                        <Label text="👥" style="-fx-font-size:20px;"/>
                    </VBox>
                    <VBox spacing="2">
                        <Label text="Usuarios Registrados" styleClass="stat-label"/>
                        <Label fx:id="lblTotalUsuarios" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
                <Label text="registrados" styleClass="stat-trend-up"/>
            </VBox>

            <!-- Card: Compras -->
            <VBox styleClass="stat-card" spacing="12" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox styleClass="stat-icon-amber" alignment="CENTER">
                        <Label text="🧾" style="-fx-font-size:20px;"/>
                    </VBox>
                    <VBox spacing="2">
                        <Label text="Compras Totales" styleClass="stat-label"/>
                        <Label fx:id="lblTotalCompras" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
                <Label fx:id="lblComprasPagadas" text="0 pagadas" styleClass="stat-trend-up"/>
            </VBox>

            <!-- Card: Incidencias -->
            <VBox styleClass="stat-card" spacing="12" GridPane.columnIndex="3" GridPane.rowIndex="0">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox styleClass="stat-icon-rose" alignment="CENTER">
                        <Label text="⚠" style="-fx-font-size:20px;"/>
                    </VBox>
                    <VBox spacing="2">
                        <Label text="Incidencias" styleClass="stat-label"/>
                        <Label fx:id="lblTotalIncidencias" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
                <Label text="pendientes" styleClass="stat-trend-down"/>
            </VBox>

        </GridPane>

        <!-- Fila inferior: Eventos recientes + Compras recientes -->
        <HBox spacing="16" VBox.vgrow="ALWAYS">

            <!-- Eventos recientes -->
            <VBox styleClass="card" spacing="16" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Eventos Recientes" styleClass="section-title"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="Ver todos →" styleClass="btn-secondary, btn-sm"
                            onAction="#irAEventos"/>
                </HBox>
                <Pane styleClass="separator-h"/>
                <TableView fx:id="tablaEventosRecientes" VBox.vgrow="ALWAYS"
                           styleClass="table-view" prefHeight="280">
                    <columns>
                        <TableColumn fx:id="colEventoNombre" text="Evento" prefWidth="160"/>
                        <TableColumn fx:id="colEventoCiudad" text="Ciudad" prefWidth="100"/>
                        <TableColumn fx:id="colEventoFecha" text="Fecha" prefWidth="90"/>
                        <TableColumn fx:id="colEventoEstado" text="Estado" prefWidth="90"/>
                    </columns>
                    <placeholder>
                        <Label text="No hay eventos registrados" styleClass="page-subtitle"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- Compras recientes -->
            <VBox styleClass="card" spacing="16" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Compras Recientes" styleClass="section-title"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="Ver todas →" styleClass="btn-secondary, btn-sm"
                            onAction="#irACompras"/>
                </HBox>
                <Pane styleClass="separator-h"/>
                <TableView fx:id="tablaComprasRecientes" VBox.vgrow="ALWAYS"
                           styleClass="table-view" prefHeight="280">
                    <columns>
                        <TableColumn fx:id="colCompraId" text="ID" prefWidth="90"/>
                        <TableColumn fx:id="colCompraUsuario" text="Usuario" prefWidth="130"/>
                        <TableColumn fx:id="colCompraTotal" text="Total" prefWidth="80"/>
                        <TableColumn fx:id="colCompraEstado" text="Estado" prefWidth="100"/>
                    </columns>
                    <placeholder>
                        <Label text="No hay compras registradas" styleClass="page-subtitle"/>
                    </placeholder>
                </TableView>
            </VBox>

        </HBox>

    </VBox>
</ScrollPane>
